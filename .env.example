# Slack user token (xoxp-...) — requires channels:history, channels:read, groups:history, groups:read, im:history, im:read, chat:write, users:read
ATC_SLACK_TOKEN=

# LLM provider — any OpenAI-compatible endpoint works
ATC_LLM_API_KEY=
ATC_LLM_BASE_URL=https://api.anthropic.com/v1
ATC_LLM_MODEL=claude-sonnet-4-6

# Jira (optional) — basic auth: email:api_token base64-encoded
ATC_JIRA_TOKEN=
ATC_JIRA_BASE_URL=
